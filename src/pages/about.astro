---
import { getEntry, render } from "astro:content";
import { Schema } from "astro-seo-schema";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";
import { absoluteUrl } from "@/utils/path";

const entry = await getEntry("page", "about");
if (!entry) throw new Error("Missing src/content/page/about.md");
const { Content } = await render(entry);

const profile = siteConfig.profile;
const authorName = profile?.name ?? siteConfig.author;

const meta = {
	description: entry.data.description ?? `${authorName} — about me.`,
	title: entry.data.title,
};

const personSameAs = [
	profile?.linkedin,
	profile?.github,
	profile?.twitter,
	profile?.mastodon,
	profile?.pwnCollege,
	profile?.ctfTime,
].filter((s): s is string => Boolean(s));

const avatarUrl = profile?.avatar ? absoluteUrl(profile.avatar, Astro.site) : undefined;
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "ProfilePage",
		mainEntity: {
			"@type": "Person",
			name: authorName,
			...(avatarUrl ? { image: avatarUrl } : {}),
			...(profile?.jobTitle ? { jobTitle: profile.jobTitle } : {}),
			...(profile?.employer
				? {
						worksFor: {
							"@type": "Organization",
							name: profile.employer,
							...(profile.employerUrl ? { url: profile.employerUrl } : {}),
						},
					}
				: {}),
			...(profile?.alumni
				? {
						alumniOf: {
							"@type": "CollegeOrUniversity",
							name: profile.alumni,
						},
					}
				: {}),
			...(personSameAs.length ? { sameAs: personSameAs } : {}),
		},
	}}
/>

<PageLayout meta={meta}>
	<section class="about" aria-label="About">
		<div class="bio">
			<Content />
		</div>
	</section>
</PageLayout>

<style>
	.about {
		margin-bottom: 64px;
	}
	.bio {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		max-width: var(--reading-width);
	}
	.bio :global(h2) {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 21px;
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		margin: 32px 0 14px;
	}
	.bio :global(h2:first-of-type) {
		margin-top: 0;
	}
	.bio :global(ul) {
		margin: 0 0 28px;
		padding: 0;
		list-style: none;
	}
	.bio :global(ul li) {
		position: relative;
		padding-left: 22px;
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin-bottom: 10px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		text-wrap: pretty;
	}
	.bio :global(ul li:last-child) {
		margin-bottom: 0;
	}
	.bio :global(ul li::before) {
		content: "";
		position: absolute;
		left: 4px;
		top: 0.78em;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: hsl(var(--theme-accent));
	}
	.bio :global(:not(pre) > code) {
		font-family: var(--font-mono);
		font-size: 14.5px;
		background: var(--paper);
		border: 1px solid var(--hairline);
		padding: 1px 6px;
		border-radius: 3px;
		color: hsl(var(--theme-text-muted));
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
		transition:
			background-color 0.35s ease,
			border-color 0.35s ease;
	}
	.bio :global(p) {
		margin: 0 0 22px;
		text-wrap: pretty;
	}
	.bio :global(p:last-child) {
		margin-bottom: 0;
	}
	.bio :global(a) {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition:
			color 0.2s ease,
			text-decoration-color 0.2s ease;
	}
	.bio :global(a:hover) {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.bio :global(a:focus-visible) {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.bio {
			font-size: 17px;
			line-height: 1.7;
		}
	}
	@media (max-width: 420px) {
		.bio {
			font-size: 16.5px;
		}
	}
</style>
