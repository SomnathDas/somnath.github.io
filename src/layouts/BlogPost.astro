---
import { Image } from "astro:assets";
import { type CollectionEntry, render } from "astro:content";
import { Schema } from "astro-seo-schema";
import ShareButtons from "@/components/blog/ShareButtons.astro";
import { getAllPosts, sortMDByDate } from "@/data/post";
import { siteConfig } from "@/site-config";
import { formatBylineDate, formatEyebrowDate } from "@/utils/date";
import { absoluteUrl, withBase } from "@/utils/path";
import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

const sortedAll = sortMDByDate(await getAllPosts());
const idx = sortedAll.findIndex((p) => p.id === post.id);
const newerPost = idx > 0 ? sortedAll[idx - 1] : undefined;
const olderPost = idx >= 0 && idx < sortedAll.length - 1 ? sortedAll[idx + 1] : undefined;
const {
	data: { coverImage, description, ogImage, publishDate, title, updatedDate, tags, draft },
	id: slug,
} = post;
const socialImage = ogImage ?? `/og-image/${slug}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { remarkPluginFrontmatter, headings } = await render(post);

const authorName = siteConfig.profile?.name ?? siteConfig.author;
const postUrl = absoluteUrl(`/posts/${slug}/`, Astro.site);
const socialImageAbsolute = absoluteUrl(socialImage, Astro.site);

// "Posts · Month YYYY"
const eyebrowDate = formatEyebrowDate(publishDate);

// "2 May 2026"
const bylineDate = formatBylineDate(publishDate);

// Prefer remark plugin's value; fall back to "".
const readingTime: string =
	(remarkPluginFrontmatter as { minutesRead?: string })?.minutesRead ?? "";
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		headline: title,
		datePublished: articleDate,
		dateModified: updatedDate?.toISOString(),
		url: postUrl,
		image: socialImageAbsolute,
		author: {
			"@type": "Person",
			name: authorName,
		},
		description: description,
	}}
/>

<BaseLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<div class="post-shell">
		<header class="post-header-area">
			<div class="post-header-main">
				<div id="blog-hero" class="post-header">
					<div class="post-eyebrow">
						Posts <span class="sep">·</span>
						{eyebrowDate}
					</div>
					{draft && <span class="draft-flag">(Draft)</span>}
					<h1 class="post-title">{title}</h1>
					<p class="byline">
						{
							authorName && (
								<>
									By {authorName}
									<span class="sep">·</span>
								</>
							)
						}{bylineDate}{
							readingTime && (
								<>
									<span class="sep">·</span>
									{readingTime}
								</>
							)
						}
					</p>
					{
						!!tags?.length && (
							<div class="post-tags">
								{tags.map((tag, i) => (
									<>
										<span data-pagefind-filter="tag">{tag}</span>
										{i < tags.length - 1 && <span class="sep">·</span>}
									</>
								))}
							</div>
						)
					}
					{
						updatedDate && (
							<div class="post-updated">
								Updated{" "}
								<time datetime={updatedDate.toISOString()}>{formatBylineDate(updatedDate)}</time>
							</div>
						)
					}
				</div>

				{
					coverImage ? (
						<figure class="post-cover">
							<Image
								src={coverImage.src}
								alt={coverImage.alt}
								loading="eager"
								fetchpriority="high"
								decoding="async"
								widths={[480, 720, 960, 1280]}
								sizes="(max-width: 720px) 92vw, 696px"
							/>
						</figure>
					) : (
						<hr class="rule" />
					)
				}
			</div>
			<div class="post-header-spacer"></div>
		</header>

		<div class="post-content-area">
			<div class="post-main" data-pagefind-body>
				<article class="post-article">
					<slot />
				</article>

				<ShareButtons title={title} url={postUrl} description={description} />

				<hr class="rule rule--footer" />

				{
					(olderPost || newerPost) && (
						<nav class="post-pager" aria-label="More posts">
							{olderPost && (
								<a
									class="pager-link prev"
									data-astro-prefetch
									href={withBase(`/posts/${olderPost.id}/`)}
								>
									<span class="pager-eyebrow">Older</span>
									<span class="pager-title">{olderPost.data.title}</span>
								</a>
							)}
							{newerPost && (
								<a
									class="pager-link next"
									data-astro-prefetch
									href={withBase(`/posts/${newerPost.id}/`)}
								>
									<span class="pager-eyebrow">Newer</span>
									<span class="pager-title">{newerPost.data.title}</span>
								</a>
							)}
						</nav>
					)
				}
			</div>
			{
				headings.length > 0 && (
					<aside class="post-toc-wrapper">
						<div class="toc-card is-collapsed">
							<h2 class="toc-title">Table of Contents</h2>
							<nav class="toc-nav">
								<ul class="toc-list">
									{headings
										.filter((h) => h.depth === 2 || h.depth === 3)
										.map((heading, index) => (
											<li class={`toc-item depth-${heading.depth}`}>
												<span class="toc-marker" />
												<a href={`#${heading.slug}`} class="toc-link">
													<span class="toc-number">{index + 1}</span>
													<span class="toc-text">{heading.text}</span>
												</a>
											</li>
										))}
								</ul>
							</nav>
							{headings.filter((h) => h.depth === 2 || h.depth === 3).length > 3 && (
								<button type="button" class="toc-toggle" id="toc-toggle">
									<span class="toggle-text">Show all</span>
									<svg
										class="toggle-icon"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
									</svg>
								</button>
							)}
						</div>
					</aside>
				)
			}
		</div>
	</div>

	<button aria-label="Back to Top" class="to-top-btn" data-show="false" id="to-top-btn">
		<svg
			aria-hidden="true"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<style>
	/* Expand parent layout container on posts pages */
	:global(.wrap:has(.post-shell)) {
		max-width: 1120px;
	}

	.post-shell {
		display: block;
		position: relative;
	}

	.post-header-area {
		display: block;
		margin-bottom: 28px;
	}

	.post-content-area {
		display: flex;
		flex-direction: column;
	}

	/* On mobile/tablet, show TOC above the article */
	.post-toc-wrapper {
		order: -1;
		margin-bottom: 36px;
		width: 100%;
	}

	@media (min-width: 1100px) {
		/* Align header with the article column */
		.post-header-area {
			display: grid;
			grid-template-columns: minmax(0, 760px) 240px;
			column-gap: 64px;
			justify-content: center;
			max-width: none;
			margin: 0 auto;
		}
		.post-header-main {
			grid-column: 1;
		}

		/* Grid for desktop layout */
		.post-content-area {
			display: grid;
			grid-template-columns: minmax(0, 760px) 240px;
			column-gap: 64px;
			justify-content: center;
		}
		.post-main {
			grid-column: 1;
		}
		.post-toc-wrapper {
			grid-column: 2;
			order: 0;
			margin-bottom: 0;
			display: block;
		}
		.toc-card {
			position: sticky;
			top: 56px;
			max-height: calc(100vh - 112px);
			overflow-y: auto;
			scrollbar-width: thin;
		}
	}

	/* Timeline Box Styling */
	.toc-card {
		background: var(--paper);
		border: 1px solid var(--hairline);
		border-radius: 8px;
		padding: 20px;
		transition:
			background-color 0.35s ease,
			border-color 0.35s ease;
	}

	.toc-title {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
		margin: 0 0 16px;
	}

	.toc-list {
		position: relative;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	/* The vertical line running down the timeline */
	.toc-list::before {
		content: "";
		position: absolute;
		left: 5.5px; /* Center of the 12px width marker (12/2 - 0.5px line width) */
		top: 10px;
		bottom: 10px;
		width: 1px;
		background-color: var(--hairline);
		z-index: 1;
		transition: background-color 0.35s ease;
	}

	.toc-item {
		display: flex;
		align-items: center;
		position: relative;
		margin-bottom: 10px;
		z-index: 2;
	}

	.toc-item:last-child {
		margin-bottom: 0;
	}

	/* Indent text for subheadings (depth-3) */
	.toc-item.depth-3 .toc-link {
		padding-left: 28px;
	}

	/* Circle marker along the timeline */
	.toc-marker {
		width: 12px;
		height: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--paper);
		border: 1px solid var(--faint);
		border-radius: 50%;
		margin-right: 14px;
		flex-shrink: 0;
		z-index: 3;
		transition:
			border-color 0.25s ease,
			background-color 0.25s ease;
	}

	.toc-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		color: hsl(var(--theme-text-muted) / 0.85);
		font-family: var(--font-sans);
		font-size: 13px; /* Clean, compact, and consistent size */
		padding: 5px 10px;
		border-radius: 6px;
		border: 1px solid transparent;
		transition: all 0.2s ease;
		flex-grow: 1;
		min-width: 0;
	}

	.toc-number {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.72);
		margin-right: 10px;
		width: 14px;
		text-align: right;
		flex-shrink: 0;
		transition: color 0.2s ease;
	}

	.toc-text {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.toc-link:hover {
		color: hsl(var(--theme-accent));
	}

	/* Active Highlight state (Timeline Marker + Capsule Background) */
	.toc-item.active .toc-marker {
		border-color: hsl(var(--theme-accent));
		background-color: hsl(var(--theme-accent));
	}

	.toc-item.active .toc-link {
		background: var(--accent-soft);
		border-color: hsl(var(--theme-accent) / 0.15);
		color: hsl(var(--theme-text));
	}

	.toc-item.active .toc-number {
		color: hsl(var(--theme-accent) / 0.7);
	}

	/* Collapsible toggle styles for mobile */
	.toc-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		width: 100%;
		padding: 8px;
		margin-top: 14px;
		background: transparent;
		border: 1px solid var(--hairline);
		border-radius: 6px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.72);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.toc-toggle:hover {
		background: var(--accent-soft);
		color: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent) / 0.2);
	}

	.toc-toggle svg {
		width: 14px;
		height: 14px;
		transition: transform 0.2s ease;
	}

	/* Collapsible Logic */
	@media (max-width: 1100px) {
		.toc-card.is-collapsed .toc-item:nth-child(n + 4) {
			display: none;
		}
	}

	@media (min-width: 1100px) {
		.toc-toggle {
			display: none;
		}
	}

	.post-cover {
		margin: 0 0 36px;
		padding: 0;
	}
	.post-cover img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 380px;
		object-fit: cover;
		border: 1px solid var(--hairline);
		border-radius: 4px;
		background: var(--paper);
	}

	.post-eyebrow {
		font-family: var(--font-mono);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
		margin-bottom: 22px;
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	.post-eyebrow .sep {
		color: var(--faint);
		margin: 0 8px;
	}

	.draft-flag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: #c14a2b;
		margin-bottom: 12px;
		letter-spacing: 0.08em;
	}

	.post-title {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: clamp(28px, 5.5vw, 46px);
		letter-spacing: -0.022em;
		line-height: 1.1;
		color: hsl(var(--theme-text));
		margin: 0 0 18px;
		word-wrap: break-word;
		overflow-wrap: break-word;
	}
	.post-title :global(em) {
		font-style: italic;
		color: hsl(var(--theme-accent));
		font-weight: 400;
	}

	.byline {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 16.5px;
		color: hsl(var(--theme-text-muted));
		margin: 0 0 14px;
		line-height: 1.5;
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	.byline .sep {
		color: var(--faint);
		margin: 0 6px;
		font-style: normal;
	}

	.post-tags {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.72);
		letter-spacing: 0.02em;
		margin-bottom: 32px;
		word-break: break-word;
	}
	.post-tags .sep {
		color: var(--faint);
		margin: 0 6px;
	}

	.post-updated {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
		margin: -16px 0 32px;
	}

	.rule {
		height: 1px;
		background: var(--hairline);
		border: 0;
		margin: 0 0 44px;
		transition: background-color 0.35s ease;
	}
	/* Extra spacing so stacked footer blocks (post-end link, comments) read as intentional. */
	.rule--footer {
		margin: 56px 0 28px;
	}

	/* Prev/Next post navigation */
	.post-pager {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 32px;
		row-gap: 28px;
		margin: 0 0 56px;
		padding: 0 0 0 0;
	}
	.pager-link {
		display: block;
		text-decoration: none;
		min-width: 0;
		transition: transform 0.25s ease;
	}
	.pager-link.next {
		text-align: right;
	}
	.pager-link.prev:hover {
		transform: translateX(-2px);
	}
	.pager-link.next:hover {
		transform: translateX(2px);
	}
	.pager-eyebrow {
		display: block;
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.72);
		margin-bottom: 8px;
	}
	.pager-link.prev .pager-eyebrow::before {
		content: "← ";
	}
	.pager-link.next .pager-eyebrow::after {
		content: " →";
	}
	.pager-title {
		display: block;
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.3;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		text-wrap: balance;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		transition: color 0.2s ease;
	}
	.pager-link:hover .pager-title {
		color: hsl(var(--theme-accent));
	}
	/* Lone prev/next spans full width, text on its natural side. */
	.post-pager:has(.pager-link.prev:only-child) .pager-link.prev,
	.post-pager:has(.pager-link.next:only-child) .pager-link.next {
		grid-column: 1 / -1;
	}
	@media (max-width: 720px) {
		.post-pager {
			grid-template-columns: 1fr;
			row-gap: 22px;
			margin-bottom: 40px;
		}
		.pager-link.next {
			order: 0;
			text-align: left;
		}
		.pager-link.prev {
			order: 1;
		}
	}

	.to-top-btn {
		position: fixed;
		bottom: 32px;
		right: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 999px;
		border: 1px solid transparent;
		background: var(--accent-soft);
		color: hsl(var(--theme-text-muted));
		cursor: pointer;
		opacity: 0;
		transform: translateY(28px);
		transition:
			opacity 0.3s ease,
			transform 0.3s ease,
			color 0.2s ease,
			border-color 0.2s ease;
		z-index: 90;
	}
	.to-top-btn[data-show="true"] {
		opacity: 1;
		transform: translateY(0);
	}
	.to-top-btn:hover {
		color: hsl(var(--theme-accent));
		border-color: var(--hairline);
	}
	.to-top-btn svg {
		width: 20px;
		height: 20px;
	}
	@media (min-width: 720px) {
		.to-top-btn {
			right: 32px;
			bottom: 32px;
			width: 44px;
			height: 44px;
		}
	}

	@media (max-width: 720px) {
		.post-title {
			font-size: 30px;
			line-height: 1.15;
		}
		.byline {
			font-size: 15.5px;
		}
		.rule {
			margin-bottom: 32px;
		}
	}
	@media (max-width: 420px) {
		.post-eyebrow {
			font-size: 11px;
			margin-bottom: 18px;
		}
		.post-eyebrow .sep {
			margin: 0 6px;
		}
		.post-title {
			font-size: 26px;
		}
		.byline {
			font-size: 14.5px;
			margin-bottom: 24px;
		}
		.rule {
			margin-bottom: 26px;
		}
		.post-end {
			font-size: 14px;
		}
	}

	.post-end a:focus-visible,
	.to-top-btn:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
</style>

<style is:global>
	.post-article {
		font-family: var(--font-serif);
		color: hsl(var(--theme-text));
	}

	.post-article > p {
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		margin: 0 0 24px;
		max-width: var(--reading-width);
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post-article > p:first-of-type::first-letter {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 500;
		color: hsl(var(--theme-accent));
		float: left;
		font-size: 3.6em;
		line-height: 0.92;
		padding: 4px 10px 0 0;
		margin-top: 4px;
	}
	.post-article p em,
	.post-article em {
		font-style: italic;
	}
	.post-article p strong,
	.post-article strong {
		font-weight: 500;
		color: hsl(var(--theme-text));
	}

	.post-article h2 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 27px;
		line-height: 1.22;
		letter-spacing: -0.014em;
		color: hsl(var(--theme-text));
		margin: 56px 0 20px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		scroll-margin-top: 60.5px;
	}
	.post-article h3 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-style: italic;
		font-size: 20px;
		line-height: 1.3;
		letter-spacing: -0.005em;
		color: hsl(var(--theme-text));
		margin: 38px 0 14px;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		scroll-margin-top: 60.5px;
	}
	.post-article h4 {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 17.5px;
		line-height: 1.35;
		color: hsl(var(--theme-text));
		margin: 30px 0 12px;
		scroll-margin-top: 60.5px;
	}

	.post-article a {
