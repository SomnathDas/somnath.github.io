	.post-article a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
</style>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement | null;
	const heroEl = document.getElementById("blog-hero") as HTMLDivElement | null;
	if (scrollBtn && heroEl) {
		new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		}).observe(heroEl);
		scrollBtn.addEventListener("click", () =>
			document.documentElement.scrollTo({ behavior: "smooth", top: 0 }),
		);
	}

	const lazyImgs = document.querySelectorAll<HTMLImageElement>('.post-article img[loading="lazy"]');
	if (lazyImgs.length && "IntersectionObserver" in window) {
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						(e.target as HTMLElement).dataset.in = "1";
						io.unobserve(e.target);
					}
				});
			},
			{ rootMargin: "800px 0px" },
		);
		lazyImgs.forEach((img) => io.observe(img));
	}

	const slugify = (s: string) =>
		s
			.toLowerCase()
			.trim()
			.replace(/[^a-z0-9]+/g, "-")
			.replace(/^-+|-+$/g, "");
	const usedIds = new Set<string>();
	document
		.querySelectorAll<HTMLHeadingElement>(".post-article h2, .post-article h3")
		.forEach((h) => {
			const baseId = h.id || slugify(h.textContent ?? "");
			if (!baseId) return;
			let id = baseId;
			for (let n = 2; usedIds.has(id); n++) id = `${baseId}-${n}`;
			usedIds.add(id);
			if (!h.id) h.id = id;

			const btn = document.createElement("button");
			btn.type = "button";
			btn.className = "heading-anchor";
			btn.setAttribute("aria-label", `Copy link to ${h.textContent ?? "section"}`);
			btn.textContent = "#";
			btn.addEventListener("click", async () => {
				const url = `${location.origin}${location.pathname}#${id}`;
				try {
					await navigator.clipboard.writeText(url);
					btn.textContent = "✓";
					setTimeout(() => (btn.textContent = "#"), 1200);
				} catch {}
			});
			h.prepend(btn);
		});

	// Table of Contents Collapse/Expand Toggle
	const toggleBtn = document.getElementById("toc-toggle");
	const tocCard = document.querySelector(".toc-card");
	if (toggleBtn && tocCard) {
		toggleBtn.addEventListener("click", () => {
			const isCollapsed = tocCard.classList.toggle("is-collapsed");
			const text = toggleBtn.querySelector(".toggle-text");
			const icon = toggleBtn.querySelector(".toggle-icon") as HTMLElement | null;
			if (text) text.textContent = isCollapsed ? "Show all" : "Show less";
			if (icon) {
				icon.style.transform = isCollapsed ? "rotate(0deg)" : "rotate(180deg)";
			}
		});
	}

	// Table of Contents Active Link Highlight
	const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".post-toc-wrapper a");
	const headingElements = Array.from(
		document.querySelectorAll<HTMLHeadingElement>(".post-article h2, .post-article h3"),
	);

	if (tocLinks.length > 0 && headingElements.length > 0) {
		const updateActiveHeading = () => {
			let activeId: string | null = null;
			const isAtBottom =
				window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 10;

			if (isAtBottom) {
				activeId = headingElements[headingElements.length - 1].id;
			} else {
				for (const heading of headingElements) {
					const rect = heading.getBoundingClientRect();
					if (rect.top < 120) {
						activeId = heading.id;
					} else {
						break;
					}
				}
			}

			tocLinks.forEach((link) => {
				const href = link.getAttribute("href");
				const item = link.closest(".toc-item");
				if (activeId && href === `#${activeId}`) {
					link.classList.add("active");
					if (item) item.classList.add("active");
				} else {
					link.classList.remove("active");
					if (item) item.classList.remove("active");
				}
			});
		};

		window.addEventListener("scroll", updateActiveHeading, { passive: true });
		updateActiveHeading();
	}
</script>
